generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Pipeline {
  id                String       @id @default(uuid())
  rawInput          String
  status            String       @default("ideation")
  angles            String?      // JSON string of GeneratedAngle[]
  selectedAngle     String?
  selectedMediaType String?      // MediaType
  mediaContent      String?      // JSON string of MediaContent
  rejectionFeedback String?
  socialPost        String?      // JSON string of SocialPost
  brandId           String?
  brand             BrandProfile? @relation(fields: [brandId], references: [id])
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model ScheduledPost {
  id            String       @id @default(uuid())
  content       String       // JSON string of MediaContent
  platforms     String       // JSON string of string[]
  scheduledTime DateTime
  status        String       @default("pending")
  error         String?
  externalJobId String?      // ID from external scheduler (Upload-Post)
  createdAt     DateTime     @default(now())
  brandId       String?      // Link to brand context
  brand         BrandProfile? @relation(fields: [brandId], references: [id])
}

model BrandProfile {
  id              String           @id @default(uuid())
  companyName     String           @default("")
  industry        String           @default("")
  targetAudience  String           @default("")
  toneOfVoice     String           @default("Professional")
  keywords        String           @default("") // Comma separated
  updatedAt       DateTime         @updatedAt
  scheduledPosts  ScheduledPost[]
  pipelines       Pipeline[]
}
